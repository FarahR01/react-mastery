{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "vite",
  "env": {
    "NODE_VERSION": "24.x"
  },
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs24.x",
      "maxDuration": 30,
      "memory": 3008
    }
  },
  "regions": ["iad1"],
  "nodeVersion": "24.x",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "skewProtection": {
    "enabled": true
  },
  "env": {
    "NODE_ENV": "production",
    "VITE_APP_ENV": "production"
  }
}
